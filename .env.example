# Copiar a .env o configurar en el panel del hosting (no commitear secretos reales).

# Google OAuth — https://console.cloud.google.com/
# GOOGLE_CLIENT_ID      → backend (verifica el token de Google)
# VITE_GOOGLE_CLIENT_ID → frontend (expuesto en el build de Vite, mismo valor)
# GOOGLE_CLIENT_SECRET  → solo si usas el flujo de Authorization Code (server-side)
# GOOGLE_REDIRECT_URI   → URI de redirección registrada en Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://127.0.0.1:5173

# Obligatorio en producción (NODE_ENV=production)
JWT_SECRET=

# Orígenes CORS permitidos (coma, sin espacios problemáticos). Ej: https://app.ejemplo.com
# Use * solo si acepta el riesgo (API usable desde cualquier sitio en navegador).
# SYSCOM_CORS_ORIGINS=https://app.ejemplo.com

# Puerto HTTP del servidor (por defecto 3001)
# PORT=3001
# Si cambias PORT, en desarrollo define el mismo valor para el proxy de Vite:
# VITE_API_PORT=3001

# Base de datos SQLite (ruta persistente en el servidor)
# SYSCOM_SQLITE_PATH=/var/lib/syscom-iot/data.sqlite

# Front compilado: ejecutar `npm run build` antes de `npm start`.
# Si API y front están en hosts distintos al construir el front:
# VITE_API_BASE=https://api.ejemplo.com/api
