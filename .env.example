# Copiar a .env o configurar en el panel del hosting (no commitear secretos reales).

# Google OAuth — https://console.cloud.google.com/
# GOOGLE_CLIENT_ID      → backend (verifica el token de Google)
# VITE_GOOGLE_CLIENT_ID → frontend (expuesto en el build de Vite, mismo valor)
# GOOGLE_CLIENT_SECRET  → solo si usas el flujo de Authorization Code (server-side)
# GOOGLE_REDIRECT_URI   → URI de redirección registrada en Google Cloud Console
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://127.0.0.1:5173
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=https://127.0.0.1:5173

# Obligatorio en producción (NODE_ENV=production)
JWT_SECRET=

# Sesión JWT del panel (jsonwebtoken `expiresIn`, p. ej. 90d, 8h). Por defecto 90d (monitoreo / kiosco).
# En entornos estrictos use un valor corto y confíe en el refresh periódico del cliente.
# SYSCOM_JWT_EXPIRES=90d
# Tras el `exp` del JWT, POST /api/auth/refresh y SSE (?token=) aceptan el token solo hasta este margen (ms). Por defecto ~30 días.
# SYSCOM_JWT_REFRESH_GRACE_MS=2592000000

# Orígenes CORS permitidos (coma, sin espacios problemáticos). Ej: https://app.ejemplo.com
# Use * solo si acepta el riesgo (API usable desde cualquier sitio en navegador).
# SYSCOM_CORS_ORIGINS=https://app.ejemplo.com

# Puerto HTTP del servidor (por defecto 3001)
# PORT=3001
# Si cambias PORT, en desarrollo define el mismo valor para el proxy de Vite:
# VITE_API_PORT=3001

# Base de datos SQLite (ruta persistente en el servidor)
# SYSCOM_SQLITE_PATH=/var/lib/syscom-iot/data.sqlite

# Front compilado: ejecutar `npm run build` antes de `npm start`.
# Si API y front están en hosts distintos al construir el front:
# VITE_API_BASE=https://api.ejemplo.com/api

# ── LoRaWAN LNS integrado (solo US915: 902–928 MHz; UDP 1700 por defecto) ───
# SYSCOM_LNS_PLAN: solo se admite US915; otros valores se ignoran (aviso en log).
# SYSCOM_LNS_RX2_FREQ debe estar entre 902 y 928 MHz si se define.
# SYSCOM_LNS_PLAN=US915
# Puerto Semtech GWMP; por defecto 1700. En PaaS solo HTTP (p. ej. Render): LNS_UDP_PORT=0
# Si otro proceso usa 1700 en su PC: LNS_UDP_PORT=0 o otro puerto libre
# LNS_UDP_PORT=1700
# SYSCOM_LNS_RX2_FREQ=923.3
# SYSCOM_LNS_RX2_DATR=SF12BW500
# Desactivar motor MAC cifrado (no usar en producción salvo diagnóstico):
# SYSCOM_LNS_MAC=0
# FPort de respaldo solo si el dispositivo no tiene canal en decode-config (preferir plantilla):
# SYSCOM_LNS_DEFAULT_FPORT=85
#
# US915 / clase A: RX1 = 5 s en µs respecto al tmst del último uplink (anula rx_delay_sec de sesión si se define)
# SYSCOM_LNS_RX1_DELAY_US=5000000
# RxDelay en Join-Accept (1–15 s); por defecto en motor 5 si no se define:
# SYSCOM_LNS_RX_DELAY_SEC=5
# SYSCOM_LNS_CLASS_A_RX_WINDOW=RX1
# Margen ms tras RxDelay(s) para aceptar downlink clase A tras el uplink (por defecto 2000):
# SYSCOM_LNS_CLASS_A_UPLINK_GRACE_MS=2000
# SYSCOM_LNS_TX_ACK_ENABLED=0
# SYSCOM_LNS_APP_DOWNLINK_TX_ACK=0
# Reintento tras GW_TX_ACK con error (ms) antes de reencolar el mismo PULL_RESP:
# SYSCOM_LNS_TX_ACK_RETRY_MS=750
# Join-Accept US915: CFList 16 B (ChMask FSB2 canales 8–15 y 65–70). 0/false = sin CFList.
# SYSCOM_LNS_JOIN_CFLIST=1
# SYSCOM_LNS_TX_ACK_TIMEOUT_MS=5000
# SYSCOM_LNS_CLASS_C_TX_GAP_MS=800
# SYSCOM_LNS_TX_RFCH_IMME_US915=0
# SYSCOM_LNS_TX_POWER=20
#
# Listado de dispositivos: por defecto solo etiquetas UC300 y WS101 (`user_devices.tag`).
# Para admitir otros modelos: SYSCOM_DEVICE_TAG_ALLOWLIST=UC300,WS101,EM500
# Para desactivar el filtro por tag: SYSCOM_DEVICE_TAG_ALLOWLIST=*
# SYSCOM_DEVICE_TAG_ALLOWLIST=UC300,WS101
